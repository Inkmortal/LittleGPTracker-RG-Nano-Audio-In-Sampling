# Scale/free override workflow:
# New projects default to Key: -- so note editing stays chromatic until a key
# is chosen. L+d-pad on a phrase note is a quick chromatic override when a key
# and non-chromatic scale are active.
route boot.new_project_random
expect_view song

sim_set_scale 21
sim_set_song_chain 0 0 0
sim_set_chain_phrase 0 0 0 0
sim_set_phrase_note 0 0 60 0

route song.to_chain
wait 120
expect_view chain
route chain.to_phrase
wait 120
expect_view phrase
expect_screen_text C  3

# Key: -- keeps normal chromatic note edits even with a non-chromatic scale set.
route combo.a.right
wait 120
expect_screen_text C# 3
route combo.a.left
wait 120
expect_screen_text C  3

# Once Key is set, A+d-pad follows the key/scale and L+d-pad overrides it.
sim_set_key 0
route combo.a.right
wait 120
expect_screen_text D  3
route combo.l.right
wait 120
expect_screen_text D# 3

route phrase.to_chain
wait 120
route chain.to_song
wait 120
route song.to_project
wait 120
expect_view project
expect_screen_text Key: C
expect_screen_text Scale: Ionian mode (major)
expect_size 240 240
expect_no_error
quit
