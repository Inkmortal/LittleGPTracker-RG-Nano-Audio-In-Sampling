# Start on Instrument should preview the current sample instrument trim window.
route boot.new_project_random
expect_view song
press a 80
wait 100
route song.to_chain
press a 80
wait 100
route chain.to_phrase
press a 80
wait 100
route phrase.to_instrument
expect_view instrument

sim_import_sample_to_instrument 0 wuxia-guzheng.wav
sim_set_sample_trim 0 1200 5200
expect_instrument_sample 0 wuxia-guzheng.wav
expect_screen_text SOURCE

# Source sample row quick-trim aliases must not change the assigned sample.
down a
press d 80
up a
wait 120
expect_screen_text EDIT LSTART
expect_instrument_sample 0 wuxia-guzheng.wav
expect_sample_trim_order 0
down a
press r 80
up a
wait 120
expect_screen_text EDIT LSTART
expect_instrument_sample 0 wuxia-guzheng.wav
expect_sample_trim_order 0

# RB+A+Left/Right is the fast trim nudge on the Source sample row.
down a
press d 80
up a
wait 80
expect_screen_text EDIT END
down n
down a
press l 80
press l 80
press l 80
press l 80
up a
up n
wait 120
expect_sample_trim_order 0
expect_instrument_sample 0 wuxia-guzheng.wav
down a
press u 80
press u 80
up a
wait 80
expect_screen_text EDIT START
down n
down a
press r 80
press r 80
press r 80
press r 80
up a
up n
wait 120
expect_sample_trim_order 0
expect_instrument_sample 0 wuxia-guzheng.wav

reset_audio_stats
start_audio_capture instrument-start-trim-preview.wav
press s 80
wait 500
expect_player_running yes
expect_play_mode audition
expect_screen_text AUDITION
expect_audio_activity 32
expect_audio_capture_bytes 80000
press s 80
wait 160
expect_player_running no
end_audio_capture
expect_view instrument
expect_no_error
quit
