# Full uploaded-sample workflow:
# seed sample library externally, build a tiny song skeleton, open sample import,
# import selected WAV, and assert it lands in the active project's samples folder.
route boot.new_project_random
expect_view song
press a 80
wait 120
route song.to_chain
wait 120
expect_view chain
press a 80
wait 120
route chain.to_phrase
wait 120
expect_view phrase
press a 80
wait 120
route phrase.to_instrument
wait 120
expect_view instrument
route instrument.open_sample_import
route sample_import.to_first_file
press a 80
wait 120
expect_streaming_sample rgnano-test-tone.wav
route sample_import.quick_import_selected
expect_project_sample rgnano-test-tone.wav
screenshot sample-import-workflow.bmp
expect_size 240 240
expect_colors 4
expect_no_error
quit
