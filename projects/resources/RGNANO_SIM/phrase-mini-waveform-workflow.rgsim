# Phrase mini waveform workflow:
# Build a small audible phrase, preview it from the Phrase screen, and verify
# the RG Nano mini waveform updates without leaving the Phrase editor.
route boot.new_project_random
expect_view song

sim_set_tempo 82
sim_import_sample_to_instrument 0 lofi-kick.wav
sim_import_sample_to_instrument 1 lofi-snare.wav
sim_import_sample_to_instrument 2 wuxia-guzheng.wav
expect_project_sample lofi-kick.wav
expect_project_sample lofi-snare.wav
expect_project_sample wuxia-guzheng.wav

sim_set_song_chain 0 0 0
sim_set_chain_phrase 0 0 0 0
sim_set_phrase_note 0 0 48 0
sim_set_phrase_note 0 4 55 2
sim_set_phrase_note 0 8 50 1
sim_set_phrase_note 0 12 60 2
expect_song_chain 0 0 00
expect_chain_phrase 0 0 00
expect_phrase_row_count 0 4

route song.to_chain
wait 160
expect_view chain
route chain.to_phrase
wait 160
expect_view phrase

reset_audio_stats
start_audio_capture phrase-mini-waveform.wav
press s 80
wait 500
expect_player_running yes
expect_play_mode phrase
screenshot_app phrase-mini-waveform-start-screen.bmp
expect_skin_frame_clean
wait 2500
screenshot_app phrase-mini-waveform-mid-screen.bmp
expect_screens_differ phrase-mini-waveform-start-screen.bmp phrase-mini-waveform-mid-screen.bmp
expect_view phrase
expect_audio_activity 64
expect_audio_capture_bytes 200000
end_audio_capture
expect_size 240 240
expect_colors 4
expect_no_error
quit
