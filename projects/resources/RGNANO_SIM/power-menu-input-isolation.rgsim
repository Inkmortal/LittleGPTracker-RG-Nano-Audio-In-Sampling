# The power menu must be isolated from tracker controls.
# Select matches RG Nano FN/Select (KEY_SELECT=k); Power stays KEY_POWER=p in the simulator.
route boot.new_project_random
expect_view song
dump_state after boot
reset_audio_stats
press k 80
wait 120
expect_view song
expect_audio_silence 0
press p 80
wait 160
expect_view song
expect_selected_text Exit
dump_state power menu open
expect_audio_silence 0
press p 80
wait 120
expect_view song
expect_audio_silence 0
expect_no_error
quit
