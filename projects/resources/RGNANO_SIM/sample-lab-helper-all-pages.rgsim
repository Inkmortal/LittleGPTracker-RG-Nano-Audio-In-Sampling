# Verify R+Select helper coverage on every sample workstation lab page.
route boot.new_project_random
expect_view song
press a 80
wait 100
route song.to_chain
press a 80
wait 100
route chain.to_phrase
press a 80
wait 100
route phrase.to_instrument
expect_view instrument

sim_import_sample_to_instrument 0 wuxia-guzheng.wav
expect_instrument_sample 0 wuxia-guzheng.wav
expect_screen_text SOURCE

# Source helper
down n
press k 80
up n
wait 100
expect_screen_text INSTR
expect_screen_text MAP
expect_screen_text Source: sample/root
screenshot_app helper-source-map.bmp
press d 80
wait 80
expect_screen_text COMMANDS
expect_screen_text A on sample: import
expect_screen_text Sel on root: suggest/use
expect_screen_text L+UD choose S/L/E mark
expect_screen_text Start trim preview
screenshot_app helper-source-commands.bmp
down n
press k 80
up n
wait 80

# Shape helper
route combo.l.right
wait 100
expect_screen_text SHAPE
down n
press k 80
up n
wait 100
expect_screen_text Shape: level/pan/grit
screenshot_app helper-shape-map.bmp
press d 80
wait 80
expect_screen_text A+UD larger changes
screenshot_app helper-shape-commands.bmp
down n
press k 80
up n
wait 80

# Filter helper
route combo.l.right
wait 100
expect_screen_text FILTER
down n
press k 80
up n
wait 100
expect_screen_text Filter: cutoff/reso
screenshot_app helper-filter-map.bmp
press d 80
wait 80
expect_screen_text Cut/res/type/mode
screenshot_app helper-filter-commands.bmp
down n
press k 80
up n
wait 80

# Loop helper
route combo.l.right
wait 100
expect_screen_text LOOP
down n
press k 80
up n
wait 100
expect_screen_text Loop: trim window
screenshot_app helper-loop-map.bmp
press d 80
wait 80
expect_screen_text Dpad to start/lstart/end
expect_screen_text Sel root from trim
expect_screen_text Start trim preview
screenshot_app helper-loop-commands.bmp
down n
press k 80
up n
wait 80

# Motion helper
route combo.l.right
wait 100
expect_screen_text MOTION
down n
press k 80
up n
wait 100
expect_screen_text Motion: table/fb
screenshot_app helper-motion-map.bmp
press d 80
wait 80
expect_screen_text A on table: make/open
expect_screen_text R+Down inst table
screenshot_app helper-motion-commands.bmp
down n
press k 80
up n
wait 80

expect_no_error
quit
