# Universal context/minimap overlay smoke test.
route boot.new_project_random
expect_view song
press a 80
wait 80
down n
press k 80
up n
wait 120
screenshot_app context-overlay-song.bmp
expect_screen_text MAP
expect_screen_text Song > Chain > Phrase
expect_screen_text Up/Dn page RB+Sel close
press d 80
wait 120
screenshot_app context-overlay-song-commands.bmp
expect_screen_text COMMANDS
expect_screen_text A paste/new chain
expect_screen_text Start play song row
expect_screen_text Up/Dn page RB+Sel close
press u 80
wait 80
expect_screen_text MAP
down n
press k 80
up n
wait 80
route song.to_chain
expect_view chain
down n
press k 80
up n
wait 120
screenshot_app context-overlay-chain.bmp
expect_screen_text CHAIN
expect_screen_text Rows=phrase playlist
press d 80
wait 120
screenshot_app context-overlay-chain-commands.bmp
expect_screen_text COMMANDS
expect_screen_text A paste/new phrase
expect_screen_text RB+Right Phrase
expect_no_error
quit
