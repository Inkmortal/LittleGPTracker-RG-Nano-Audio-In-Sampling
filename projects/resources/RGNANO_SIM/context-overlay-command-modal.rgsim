# Verify R+Select helper inside the command picker modal.
route boot.new_project_random
expect_view song
press a 80
wait 80
route song.to_chain
expect_view chain
press a 80
wait 80
route chain.to_phrase
expect_view phrase

# Move to the first command column and open the command selector.
press r 80
press r 80
press q 80
wait 120
expect_screen_text ARPG

down n
press q 80
up n
wait 120
screenshot_app context-overlay-modal-command-map.bmp
expect_screen_text COMMAND
expect_screen_text Pick tracker cmd
press d 80
wait 120
screenshot_app context-overlay-modal-command-commands.bmp
expect_screen_text A choose command
expect_screen_text B cancel
down n
press q 80
up n
wait 80
press b 80
wait 80
expect_view phrase
expect_no_error
quit
