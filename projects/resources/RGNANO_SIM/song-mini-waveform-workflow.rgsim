# Song mini waveform workflow:
# Build a small audible arrangement, play it from the Song screen, and verify
# the full-width RG Nano mini waveform updates without leaving Song view.
route boot.new_project_random
expect_view song

sim_set_tempo 86
sim_import_sample_to_instrument 0 lofi-kick.wav
sim_import_sample_to_instrument 1 lofi-snare.wav
sim_import_sample_to_instrument 2 wuxia-guzheng.wav
expect_project_sample lofi-kick.wav
expect_project_sample lofi-snare.wav
expect_project_sample wuxia-guzheng.wav

sim_set_song_chain 0 0 0
sim_set_song_chain 0 1 1
sim_set_song_chain 0 2 2
sim_set_chain_phrase 0 0 0 0
sim_set_chain_phrase 1 0 1 1
sim_set_chain_phrase 2 0 2 2
sim_set_phrase_note 0 0 36 0
sim_set_phrase_note 0 8 36 0
sim_set_phrase_note 1 4 38 1
sim_set_phrase_note 1 12 38 1
sim_set_phrase_note 2 0 55 2
sim_set_phrase_note 2 4 60 2
sim_set_phrase_note 2 8 62 2
sim_set_phrase_note 2 12 67 2
expect_song_chain 0 0 00
expect_song_chain 0 1 01
expect_song_chain 0 2 02
expect_chain_phrase 0 0 00
expect_chain_phrase 1 0 01
expect_chain_phrase 2 0 02
expect_view song

reset_audio_stats
start_audio_capture song-mini-waveform.wav
press s 80
wait 500
expect_player_running yes
expect_play_mode song
screenshot_app song-mini-waveform-start-screen.bmp
expect_skin_frame_clean
wait 2500
screenshot_app song-mini-waveform-mid-screen.bmp
expect_screens_differ song-mini-waveform-start-screen.bmp song-mini-waveform-mid-screen.bmp
expect_view song
expect_audio_activity 64
expect_audio_capture_bytes 200000
end_audio_capture
expect_size 240 240
expect_colors 4
expect_no_error
quit
