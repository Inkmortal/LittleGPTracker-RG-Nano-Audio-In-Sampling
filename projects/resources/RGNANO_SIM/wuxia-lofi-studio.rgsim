# Wuxia/donghua lofi studio workflow:
# generate/import a small traditional-meets-lofi sample palette, set up an
# 8-track arrangement, play it through LGPT, and capture a listenable WAV.
route boot.new_project_random
expect_view song

sim_set_tempo 82
sim_import_sample_to_instrument 0 lofi-kick.wav
sim_import_sample_to_instrument 1 lofi-snare.wav
sim_import_sample_to_instrument 2 lofi-hat.wav
sim_import_sample_to_instrument 3 wuxia-guzheng.wav
sim_import_sample_to_instrument 4 wuxia-dizi.wav
sim_import_sample_to_instrument 5 wuxia-erhu.wav
sim_import_sample_to_instrument 6 lofi-vinyl.wav
sim_import_sample_to_instrument 7 wuxia-drum.wav
expect_project_sample lofi-kick.wav
expect_project_sample lofi-snare.wav
expect_project_sample lofi-hat.wav
expect_project_sample wuxia-guzheng.wav
expect_project_sample wuxia-dizi.wav
expect_project_sample wuxia-erhu.wav
expect_project_sample lofi-vinyl.wav
expect_project_sample wuxia-drum.wav

# Song rows: keep all eight channels active across a long arrangement.
sim_set_song_chain 0 0 0
sim_set_song_chain 0 1 1
sim_set_song_chain 0 2 2
sim_set_song_chain 0 3 3
sim_set_song_chain 0 4 4
sim_set_song_chain 0 5 5
sim_set_song_chain 0 6 6
sim_set_song_chain 0 7 7
sim_set_song_chain 1 0 0
sim_set_song_chain 1 1 1
sim_set_song_chain 1 2 2
sim_set_song_chain 1 3 3
sim_set_song_chain 1 4 4
sim_set_song_chain 1 5 5
sim_set_song_chain 1 6 6
sim_set_song_chain 1 7 7
sim_set_song_chain 2 0 0
sim_set_song_chain 2 1 1
sim_set_song_chain 2 2 2
sim_set_song_chain 2 3 3
sim_set_song_chain 2 4 4
sim_set_song_chain 2 5 5
sim_set_song_chain 2 6 6
sim_set_song_chain 2 7 7
sim_set_song_chain 3 0 0
sim_set_song_chain 3 1 1
sim_set_song_chain 3 2 2
sim_set_song_chain 3 3 3
sim_set_song_chain 3 4 4
sim_set_song_chain 3 5 5
sim_set_song_chain 3 6 6
sim_set_song_chain 3 7 7

# Chains point at phrase lanes. Melodic lanes rotate through variations.
sim_set_chain_phrase 0 0 0 0
sim_set_chain_phrase 0 1 0 0
sim_set_chain_phrase 0 2 0 0
sim_set_chain_phrase 0 3 0 0
sim_set_chain_phrase 1 0 1 0
sim_set_chain_phrase 1 1 1 0
sim_set_chain_phrase 1 2 1 0
sim_set_chain_phrase 1 3 1 0
sim_set_chain_phrase 2 0 2 0
sim_set_chain_phrase 2 1 2 0
sim_set_chain_phrase 2 2 2 0
sim_set_chain_phrase 2 3 2 0
sim_set_chain_phrase 3 0 3 0
sim_set_chain_phrase 3 1 4 0
sim_set_chain_phrase 3 2 5 0
sim_set_chain_phrase 3 3 6 0
sim_set_chain_phrase 4 0 7 0
sim_set_chain_phrase 4 1 8 0
sim_set_chain_phrase 4 2 7 0
sim_set_chain_phrase 4 3 9 0
sim_set_chain_phrase 5 0 10 0
sim_set_chain_phrase 5 1 10 0
sim_set_chain_phrase 5 2 11 0
sim_set_chain_phrase 5 3 10 0
sim_set_chain_phrase 6 0 12 0
sim_set_chain_phrase 6 1 12 0
sim_set_chain_phrase 6 2 12 0
sim_set_chain_phrase 6 3 12 0
sim_set_chain_phrase 7 0 13 0
sim_set_chain_phrase 7 1 13 0
sim_set_chain_phrase 7 2 13 0
sim_set_chain_phrase 7 3 13 0

# Drum kit: boom-bap base plus a few off-grid pushes.
sim_set_phrase_note 0 0 48 0
sim_set_phrase_note 0 6 48 0
sim_set_phrase_note 0 10 48 0
sim_set_phrase_note 0 15 48 0
sim_set_phrase_note 1 4 50 1
sim_set_phrase_note 1 12 50 1
sim_set_phrase_note 2 2 72 2
sim_set_phrase_note 2 6 72 2
sim_set_phrase_note 2 10 72 2
sim_set_phrase_note 2 14 72 2
sim_set_phrase_note 13 0 43 7
sim_set_phrase_note 13 8 43 7

# Guzheng/pipa-like pentatonic plucks in D minor.
sim_set_phrase_note 3 0 50 3
sim_set_phrase_note 3 4 53 3
sim_set_phrase_note 3 8 57 3
sim_set_phrase_note 3 12 60 3
sim_set_phrase_note 4 0 62 3
sim_set_phrase_note 4 4 60 3
sim_set_phrase_note 4 8 57 3
sim_set_phrase_note 4 12 53 3
sim_set_phrase_note 5 0 50 3
sim_set_phrase_note 5 3 57 3
sim_set_phrase_note 5 7 60 3
sim_set_phrase_note 5 11 65 3
sim_set_phrase_note 5 14 62 3
sim_set_phrase_note 6 0 57 3
sim_set_phrase_note 6 4 53 3
sim_set_phrase_note 6 8 50 3
sim_set_phrase_note 6 12 45 3

# Dizi/xiao lead answers and erhu long tones.
sim_set_phrase_note 7 0 74 4
sim_set_phrase_note 7 8 72 4
sim_set_phrase_note 8 4 69 4
sim_set_phrase_note 8 12 72 4
sim_set_phrase_note 9 0 77 4
sim_set_phrase_note 9 10 74 4
sim_set_phrase_note 10 0 50 5
sim_set_phrase_note 10 8 57 5
sim_set_phrase_note 11 0 53 5
sim_set_phrase_note 11 8 45 5

# Vinyl bed.
sim_set_phrase_note 12 0 48 6
sim_set_phrase_note 12 8 48 6

expect_song_chain 0 0 00
expect_chain_phrase 3 0 03
expect_phrase_row_count 3 4
expect_phrase_row_count 7 2
expect_phrase_row_count 10 2

reset_audio_stats
start_audio_capture wuxia-lofi-studio.wav
press s 80
wait 120
expect_player_running yes
expect_play_mode song
expect_playing_channel 0 00
wait 120000
expect_audio_activity 64
expect_audio_capture_bytes 18000000
end_audio_capture
route song.to_chain
wait 120
expect_view chain
expect_screen_text 1######
screenshot wuxia-lofi-studio-playing.bmp
expect_size 240 240
expect_colors 3
expect_no_error
quit
