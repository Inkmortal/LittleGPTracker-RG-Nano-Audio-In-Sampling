# Deterministic sample/instrument visual audit.
# Avoids list-position imports so sample-library changes cannot shift captures.
route boot.new_project_random
expect_view song
press a 80
wait 120
route song.to_chain
press a 80
wait 120
route chain.to_phrase
press a 80
wait 120
route phrase.to_instrument
expect_view instrument

route instrument.open_sample_import
wait 120
screenshot_app sample-full-01-import-browser.bmp
route sample_import.exit
wait 120
expect_view instrument

sim_import_sample_to_instrument 0 wuxia-guzheng.wav
expect_instrument_sample 0 wuxia-guzheng.wav
expect_screen_text SOURCE
screenshot_app sample-full-02-source-suggestion.bmp

press d 80
wait 80
expect_screen_text root
screenshot_app sample-full-03-root-focus.bmp
press k 80
wait 120
screenshot_app sample-full-04-root-accepted.bmp

down n
down a
press u 80
up a
up n
wait 160
expect_player_running yes
expect_play_mode audition
screenshot_app sample-full-05-source-audition.bmp
down n
down a
press d 80
up a
up n
wait 120
expect_player_running no

route combo.l.down
wait 120
expect_screen_text EDIT LSTART
down m
down a
press r 80
up a
up m
wait 120
expect_screen_text EDIT LSTART
screenshot_app sample-full-06-marker-edit.bmp

route combo.l.right
wait 120
expect_screen_text SHAPE
screenshot_app sample-full-07-shape.bmp
press d 80
route combo.a.up
wait 80
screenshot_app sample-full-08-shape-edit.bmp

route combo.l.right
wait 120
expect_screen_text FILTER
screenshot_app sample-full-09-filter.bmp
press d 80
route combo.a.right
wait 80
screenshot_app sample-full-10-filter-edit.bmp

route combo.l.right
wait 120
expect_screen_text LOOP
screenshot_app sample-full-11-loop.bmp
route combo.l.down
wait 80
down m
down a
press l 80
up a
up m
wait 120
screenshot_app sample-full-12-loop-marker-edit.bmp

route combo.l.right
wait 120
expect_screen_text MOTION
screenshot_app sample-full-13-motion.bmp
press d 80
route combo.a.right
wait 80
screenshot_app sample-full-14-motion-edit.bmp

down n
press k 80
up n
wait 120
screenshot_app sample-full-15-helper-map.bmp
press d 80
wait 80
screenshot_app sample-full-16-helper-commands.bmp
down n
press k 80
up n

expect_no_error
quit
