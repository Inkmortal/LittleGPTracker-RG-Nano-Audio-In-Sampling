# Mixer waveform workflow:
# Prove that the Mixer view exposes a live master waveform while tracker
# playback is producing audio.
route boot.new_project_random
expect_view song

sim_set_tempo 96
sim_import_sample_to_instrument 0 lofi-kick.wav
sim_set_song_chain 0 0 0
sim_set_chain_phrase 0 0 0 0
sim_set_phrase_note 0 0 60 0
expect_project_sample lofi-kick.wav
expect_song_chain 0 0 00
expect_chain_phrase 0 0 00
expect_phrase_row_count 0 1

reset_audio_stats
start_audio_capture mixer-waveform-workflow.wav
press s 80
wait 500
expect_player_running yes
expect_play_mode song
route song.to_mixer
wait 400
expect_view mixer
screenshot mixer-waveform-playing.bmp
screenshot_app mixer-waveform-screen.bmp
expect_skin_frame_clean
expect_audio_activity 64
expect_audio_capture_bytes 90000
end_audio_capture
expect_size 240 240
expect_colors 3
expect_no_error
quit
