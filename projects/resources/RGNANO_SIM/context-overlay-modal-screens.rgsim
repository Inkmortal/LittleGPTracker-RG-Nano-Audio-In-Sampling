# Verify R+Select helper coverage on startup and modal screens.

# Boot project selector opens as a modal before a song is loaded.
down n
press k 80
up n
wait 120
screenshot_app context-overlay-modal-projects-map.bmp
expect_screen_text PROJECTS
expect_screen_text MAP
expect_screen_text Choose/create song
press d 80
wait 120
screenshot_app context-overlay-modal-projects-commands.bmp
expect_screen_text COMMANDS
expect_screen_text A+B delete project
down n
press k 80
up n
wait 80

# New project dialog is also learnable.
press r 80
wait 80
press a 80
wait 120
down n
press k 80
up n
wait 120
screenshot_app context-overlay-modal-new-song-map.bmp
expect_screen_text NEW SONG
expect_screen_text Create project
press d 80
wait 120
screenshot_app context-overlay-modal-new-song-commands.bmp
expect_screen_text A Random makes name
down n
press k 80
up n
wait 80

expect_no_error
quit
