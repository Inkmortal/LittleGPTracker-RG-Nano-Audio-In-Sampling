# Trim-aware root detection: import detects the whole sample, trim edits clear
# that suggestion, then a trim scan detects the active region.
route boot.new_project_random
expect_view song
press a 80
wait 120
route song.to_chain
press a 80
wait 120
route chain.to_phrase
press a 80
wait 120
route phrase.to_instrument
expect_view instrument

sim_import_sample_to_instrument 0 pitch-window-fixture.wav
expect_instrument_root 0 60
expect_instrument_root_suggestion 0 60

sim_set_sample_trim 0 44100 88200
expect_instrument_root_suggestion 0 -1
sim_detect_trim_root 0 69
expect_instrument_root_suggestion 0 69

# Move from sample to root. Select accepts the trim-derived suggestion.
press d 80
press k 80
wait 120
expect_instrument_root 0 69
expect_instrument_root_suggestion 0 -1
expect_no_error
quit
