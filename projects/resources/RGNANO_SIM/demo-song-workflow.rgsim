# Build and audition a tiny RG Nano demo song:
# create a song/chain/phrase, program a melodic 8-step phrase, import a WAV
# sample onto instrument 00, return to the phrase, and assert audio output.
route boot.new_project_random
expect_view song
press a 80
wait 120
route song.to_chain
wait 120
expect_view chain
press a 80
wait 120
route chain.to_phrase
wait 120
expect_view phrase

# Row 00: C
press a 80
press d 80

# Row 01: G
press a 80
route combo.a.right
route combo.a.right
route combo.a.right
route combo.a.right
route combo.a.right
route combo.a.right
route combo.a.right
press d 80

# Row 02: high C
press a 80
route combo.a.right
route combo.a.right
route combo.a.right
route combo.a.right
route combo.a.right
press d 80

# Row 03: A
press a 80
route combo.a.left
route combo.a.left
route combo.a.left
press d 80

# Row 04: F
press a 80
route combo.a.left
route combo.a.left
route combo.a.left
route combo.a.left
press d 80

# Row 05: A
press a 80
route combo.a.right
route combo.a.right
route combo.a.right
route combo.a.right
press d 80

# Row 06: G
press a 80
route combo.a.left
route combo.a.left
press d 80

# Row 07: low C
press a 80
route combo.a.down
screenshot demo-song-programmed.bmp

route phrase.to_instrument
wait 120
expect_view instrument
route instrument.open_sample_import
route sample_import.to_first_file
route sample_import.quick_import_selected
expect_project_sample rgnano-test-tone.wav
route sample_import.exit
wait 120
expect_view instrument
reset_audio_stats
press s 80
wait 1800
expect_audio_activity 64
screenshot demo-song-playing.bmp
expect_size 240 240
expect_colors 3
expect_no_error
quit
