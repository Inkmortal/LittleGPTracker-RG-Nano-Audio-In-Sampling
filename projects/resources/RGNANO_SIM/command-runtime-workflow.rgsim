# Runtime command behavior checks for measurable tracker commands.
route boot.new_project_random
expect_view song

sim_set_tempo 120
sim_import_sample_to_instrument 0 lofi-kick.wav
sim_set_song_chain 0 0 0
sim_set_chain_phrase 0 0 0 0
sim_set_phrase_note 0 0 48 0

# Row 1 should trigger a table and switch channel 0 to groove 1.
# Keep it off the note row because a new instrument note intentionally resets
# table playback when the instrument has no assigned default table.
sim_set_phrase_command 0 1 1 TABL 0000
sim_set_phrase_command 0 1 2 GROV 0001

# Row 2 should change tempo to 96 decimal, written as hex 0060.
sim_set_phrase_command 0 2 1 TMPO 0060

# Make table 0 non-empty and prove the TABL command starts it.
sim_set_table_command 0 0 1 VOLM 0040

expect_phrase_command 0 1 1 TABL
expect_phrase_param 0 1 1 0000
expect_phrase_command 0 1 2 GROV
expect_phrase_param 0 1 2 0001
expect_phrase_command 0 2 1 TMPO
expect_phrase_param 0 2 1 0060

press s 80
wait 900
expect_player_running yes
expect_table_active 0 0
expect_groove 0 1
expect_tempo 96
expect_no_error
quit
