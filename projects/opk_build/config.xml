<CONFIG>
	<ROOTFOLDER value="/mnt/Tracks"/>
	<SAMPLELIB value="/mnt/Samples"/>
	<AUDIOBUFFERSIZE value='512'/>
	<SCREENMULT value='1'/>  <!-- Don't scale, 240x240 native -->
	<CHANNELMODE value='SPLIT'/>  <!-- SPLIT (default) or PAGED -->
	<KEY_A value="but:0:0" />
	<KEY_B value="but:0:1" />
	<KEY_LEFT value="hat:0:0:3" />
	<KEY_RIGHT value="hat:0:0:1" />
	<KEY_DOWN value="hat:0:0:2" />
	<KEY_UP value="hat:0:0:0" />
	<KEY_LSHOULDER value="but:0:5" />
	<KEY_RSHOULDER value="but:0:4" />
	<KEY_START value="but:0:7" />
	<KEY_SELECT value="but:0:6" />
	<KEYDELAY value="200"/>
	<KEYREPEAT value="100" />
	<FONTTYPE  value = '0' />     <!-- '0':original '1':digital '2':monster 'CUSTOM': load custom_font.xml-->
</CONFIG>
